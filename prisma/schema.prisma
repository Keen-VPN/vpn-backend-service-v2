generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid())
  firebaseUid             String?                  @unique @map("firebase_uid")
  appleUserId             String?                  @unique @map("apple_user_id")
  googleUserId            String?                  @unique @map("google_user_id")
  email                   String                   @unique
  displayName             String?                  @map("display_name")
  provider                String                   @default("google")
  emailVerified           Boolean                  @default(false) @map("email_verified")
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  stripeCustomerId        String?                  @unique @map("stripe_customer_id")
  stripeTrialUsedAt       DateTime?                @map("stripe_trial_used_at") @db.Timestamptz(6)
  stripeTrialSubscriptionId String?                @map("stripe_trial_subscription_id")
  trialActive             Boolean                  @default(false) @map("trial_active")
  trialStartsAt           DateTime?                @map("trial_starts_at") @db.Timestamptz(6)
  trialEndsAt             DateTime?                @map("trial_ends_at") @db.Timestamptz(6)
  trialTier               String?                  @map("trial_tier")
  longestSessionSeconds   Int                      @default(0) @map("longest_session_seconds")
  appleIAPPurchases       AppleIAPPurchase[]
  pushTokens              PushToken[]
  subscriptions           Subscription[]
  deviceTrialFingerprints DeviceTrialFingerprint[]
  trialGrant              TrialGrant?
  subscriptionUsers       SubscriptionUser[]
  primaryLinks            LinkedAccount[]      @relation("primaryLinks")
  linkedLinks             LinkedAccount[]      @relation("linkedLinks")
  connectionSessions             ConnectionSession[]
  subscriptionTransferRequests   SubscriptionTransferRequest[]
  subscriptionCreditLedgers      SubscriptionCreditLedger[]

  @@index([provider])
  @@map("users")
}

model Subscription {
  id                         String             @id @default(uuid())
  userId                     String             @map("user_id")
  stripeCustomerId           String?            @map("stripe_customer_id")
  stripeSubscriptionId       String?            @map("stripe_subscription_id")
  status                     SubscriptionStatus @default(INACTIVE)
  planId                     String?            @map("plan_id")
  planName                   String?            @map("plan_name")
  priceAmount                Decimal?           @map("price_amount") @db.Decimal(10, 2)
  priceCurrency              String?            @default("USD") @map("price_currency")
  billingPeriod              String?            @map("billing_period")
  currentPeriodStart         DateTime?          @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd           DateTime?          @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd          Boolean            @default(false) @map("cancel_at_period_end")
  cancelledAt                DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  createdAt                  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  appleEnvironment           String?            @map("apple_environment")
  appleOriginalTransactionId String?            @map("apple_original_transaction_id")
  appleProductId             String?            @map("apple_product_id")
  appleTransactionId         String?            @unique @map("apple_transaction_id")
  subscriptionType           String             @default("stripe") @map("subscription_type")
  user                       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionUsers          SubscriptionUser[]
  creditLedgerEntries        SubscriptionCreditLedger[]

  @@unique([stripeSubscriptionId, currentPeriodStart], map: "subscription_period_unique")
  @@index([userId])
  @@index([subscriptionType])
  @@index([stripeCustomerId])
  @@index([appleTransactionId])
  @@index([appleOriginalTransactionId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model AppleIAPPurchase {
  id                    String    @id @default(uuid())
  transactionId         String    @unique @map("transaction_id")
  originalTransactionId String    @unique @map("original_transaction_id")
  productId             String    @map("product_id")
  environment           String?   @map("environment")
  purchaseDate          DateTime  @map("purchase_date") @db.Timestamptz(6)
  expiresDate           DateTime? @map("expires_date") @db.Timestamptz(6)
  receiptData           String?   @map("receipt_data")
  linkedUserId          String?   @map("linked_user_id")
  linkedEmail           String?   @map("linked_email")
  linkedAt              DateTime? @map("linked_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  linkedUser            User?     @relation(fields: [linkedUserId], references: [id])

  @@index([linkedUserId])
  @@map("apple_iap_purchases")
}

model ConnectionSession {
  id                 String            @id @default(uuid())
  clientSessionId    String            @unique @map("client_session_id")
  userId             String?           @map("user_id")
  sessionStart       DateTime          @map("session_start") @db.Timestamptz(6)
  sessionEnd         DateTime?         @map("session_end") @db.Timestamptz(6)
  durationSeconds    Int               @default(0) @map("duration_seconds")
  serverLocation     String?           @map("server_location")
  platform           String
  appVersion         String?           @map("app_version")
  bytesTransferred   BigInt            @default(0) @map("bytes_transferred")
  subscriptionTier   String?           @map("subscription_tier")
  terminationReason  TerminationReason @default(USER_TERMINATION) @map("termination_reason")
  disconnectReason   String?           @map("disconnect_reason")
  eventType          EventType         @default(SESSION_START) @map("event_type")
  protocol           String?           @default("wireguard")
  networkType        String?           @map("network_type")
  heartbeatTimestamp DateTime?         @map("heartbeat_timestamp") @db.Timestamptz(6)
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionStart])
  @@index([sessionEnd])
  @@index([durationSeconds])
  @@index([platform])
  @@index([serverLocation])
  @@index([terminationReason])
  @@index([eventType])
  @@index([heartbeatTimestamp])
  @@index([createdAt])
  @@index([subscriptionTier])
  @@index([platform, sessionStart])
  @@map("connection_sessions")
}

model SessionAggregate {
  id               String   @id @default(uuid())
  aggregationDate  DateTime @map("aggregation_date") @db.Timestamptz(6)
  platform         String
  serverLocation   String   @map("server_location")
  subscriptionTier String?  @map("subscription_tier")
  totalSessions    Int      @map("total_sessions")
  totalDuration    Int      @map("total_duration")
  totalBytes       BigInt   @map("total_bytes")
  avgDuration      Int      @map("avg_duration")
  avgBytes         BigInt   @map("avg_bytes")
  uniqueUsers      Int      @map("unique_users")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([aggregationDate, platform, serverLocation, subscriptionTier])
  @@index([aggregationDate])
  @@index([platform])
  @@index([serverLocation])
  @@index([subscriptionTier])
  @@map("session_aggregates")
}

model SalesContact {
  id                       String        @id @default(uuid())
  referenceId              String        @unique @map("reference_id")
  companyName              String        @map("company_name")
  workEmail                String        @map("work_email")
  teamSize                 Int           @map("team_size")
  countryRegion            String?       @map("country_region")
  hasConsent               Boolean       @map("has_consent")
  phone                    String?       @map("phone")
  useCase                  String?       @map("use_case")
  preferredContactMethod   String?       @map("preferred_contact_method")
  preferredContactTime     String?       @map("preferred_contact_time")
  message                  String?       @map("message")
  status                   ContactStatus @default(PENDING) @map("status")
  salesTeamNotified        Boolean       @default(false) @map("sales_team_notified")
  customerConfirmationSent Boolean       @default(false) @map("customer_confirmation_sent")
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([workEmail])
  @@index([referenceId])
  @@index([createdAt])
  @@index([status])
  @@map("sales_contacts")
}

model PaidConversionSlackNotification {
  id         String   @id @default(uuid())
  dedupeKey  String   @unique @map("dedupe_key")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@map("paid_conversion_slack_notifications")
}

model TrialGrant {
  id                           String    @id @default(uuid())
  userId                       String    @unique @map("user_id")
  deviceHash                   String    @map("device_hash")
  grantedAt                    DateTime  @default(now()) @map("granted_at") @db.Timestamptz(6)
  expiresAt                    DateTime  @map("expires_at") @db.Timestamptz(6)
  channel                      String    @default("auto")
  metadata                     Json?
  slackTrialStartedNotifiedAt  DateTime? @map("slack_trial_started_notified_at") @db.Timestamptz(6)
  user                         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deviceHash], map: "trial_grants_device_hash")
  @@map("trial_grants")
}

model DeviceTrialFingerprint {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  hash      String   @unique
  platform  String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeen  DateTime @default(now()) @map("last_seen") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "trial_device_fingerprints_user_id")
  @@map("trial_device_fingerprints")
}

model PushToken {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  token       String   @unique
  deviceHash  String?  @map("device_hash")
  platform    String?  @map("platform")
  environment String?  @map("environment")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "push_tokens_user_id")
  @@map("push_tokens")
}

model SubscriptionUser {
  id              String               @id @default(uuid())
  subscriptionId  String               @map("subscription_id")
  userId          String               @map("user_id")
  role            SubscriptionUserRole  @default(OWNER)
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  subscription    Subscription         @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, userId])
  @@index([userId])
  @@index([subscriptionId])
  @@map("subscription_users")
}

model LinkedAccount {
  id              String   @id @default(uuid())
  primaryUserId   String   @map("primary_user_id")
  linkedUserId    String   @map("linked_user_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  primaryUser     User     @relation("primaryLinks", fields: [primaryUserId], references: [id], onDelete: Cascade)
  linkedUser      User     @relation("linkedLinks", fields: [linkedUserId], references: [id], onDelete: Cascade)

  @@unique([primaryUserId, linkedUserId])
  @@index([primaryUserId])
  @@index([linkedUserId])
  @@map("linked_accounts")
}

model ServerLocationPreference {
  id        String   @id @default(uuid())
  region    String
  reason    String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([region])
  @@index([createdAt])
  @@map("server_location_preferences")
}

model Node {
  id            String       @id @default(uuid())
  publicKey     String       @unique @map("public_key")
  region        String?
  ip            String       @map("ip")
  status        NodeStatus   @default(ONLINE)
  healthScore   Float        @default(100) @map("health_score")
  lastHeartbeat DateTime?    @map("last_heartbeat") @db.Timestamptz(6)
  country       String?
  city          String?
  flagUrl       String?      @map("flag_url")
  latitude      Float?
  longitude     Float?
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  clients       NodeClient[]

  @@index([region])
  @@index([status])
  @@index([region, status])
  @@map("nodes")
}

model NodeClient {
  id              String   @id @default(uuid())
  nodeId          String   @map("node_id")
  clientPublicKey String   @unique @map("client_public_key")
  allowedIps      String   @map("allowed_ips")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  node            Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@map("node_clients")
}

enum TerminationReason {
  USER_TERMINATION   @map("user_termination")
  CONNECTION_LOST    @map("connection_lost")
  HEALTH_CHECK_FAILURE @map("health_check_failure")
  RECOVERY_EXHAUSTED @map("recovery_exhausted")

  @@map("termination_reason")
}

enum EventType {
  SESSION_START @map("session_start")
  HEARTBEAT     @map("heartbeat")
  SESSION_END   @map("session_end")

  @@map("event_type")
}

enum SubscriptionStatus {
  ACTIVE    @map("active")
  INACTIVE  @map("inactive")
  TRIALING  @map("trialing")
  PAST_DUE  @map("past_due")
  CANCELLED @map("cancelled")
  EXPIRED   @map("expired")

  @@map("subscription_status")
}

enum ContactStatus {
  PENDING   @map("pending")
  CONTACTED @map("contacted")
  CONVERTED @map("converted")
  SPAM      @map("spam")

  @@map("contact_status")
}

enum NodeStatus {
  ONLINE  @map("ONLINE")
  OFFLINE @map("OFFLINE")

  @@map("node_status")
}

enum SubscriptionUserRole {
  OWNER  @map("owner")
  LINKED @map("linked")

  @@map("subscription_user_role")
}

enum TransferRequestStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")

  @@map("transfer_request_status")
}

/// Local entitlement vs Stripe billing sync after membership-transfer credit.
enum BillingAlignmentStatus {
  NOT_REQUIRED             @map("not_required")
  LOCAL_ENTITLEMENT_ONLY   @map("local_entitlement_only")
  STRIPE_ALIGNMENT_PENDING @map("stripe_alignment_pending")
  STRIPE_ALIGNED           @map("stripe_aligned")
  STRIPE_ALIGNMENT_FAILED  @map("stripe_alignment_failed")

  @@map("billing_alignment_status")
}

/// One membership transfer request per user (competitor VPN → Keen credit).
model SubscriptionTransferRequest {
  id                  String                @id @default(uuid())
  userId              String                @map("user_id")
  provider            String
  expiryDate          DateTime              @map("expiry_date") @db.Timestamptz(6)
  /// Public HTTPS URL and/or placeholder when proof is stored in proofBlob.
  proofUrl            String                @map("proof_url") @db.Text
  proofMimeType       String?               @map("proof_mime_type")
  proofBlob           Bytes?                @map("proof_blob")
  /// SHA-256 (hex) of proof bytes when proof was uploaded to S3 (abuse detection).
  proofHash           String?               @map("proof_hash") @db.VarChar(64)
  proofSizeBytes      Int?                  @map("proof_size_bytes")
  proofOriginalFilename String?             @map("proof_original_filename") @db.VarChar(255)
  proofUploadedAt     DateTime?             @map("proof_uploaded_at") @db.Timestamptz(6)
  /// Optional client-reported device fingerprint for cross-account risk checks.
  clientDeviceFingerprint String?           @map("client_device_fingerprint") @db.VarChar(128)
  riskScore           Int                   @default(0) @map("risk_score")
  /// JSON string[] — e.g. DUPLICATE_PROOF, LONG_EXPIRY, NEW_ACCOUNT, MULTIPLE_ACCOUNT_DEVICE_MATCH
  riskFlags           Json                  @default("[]") @map("risk_flags")
  status              TransferRequestStatus @default(PENDING)
  requestedCreditDays Int                   @map("requested_credit_days")
  approvedCreditDays  Int?                  @map("approved_credit_days")
  adminNote           String?               @map("admin_note") @db.Text
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  reviewedAt          DateTime?             @map("reviewed_at") @db.Timestamptz(6)
  reviewedByAdminId   String?               @map("reviewed_by_admin_id")
  billingAlignmentStatus BillingAlignmentStatus @default(NOT_REQUIRED) @map("billing_alignment_status")

  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditLedger   SubscriptionCreditLedger?

  @@unique([userId])
  @@index([status])
  @@index([createdAt])
  @@index([proofHash])
  @@map("subscription_transfer_requests")
}

/// Audit trail when admin approves transfer credit (applied subscription end date change).
model SubscriptionCreditLedger {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  transferRequestId String   @unique @map("transfer_request_id")
  creditDays        Int      @map("credit_days")
  subscriptionId    String?  @map("subscription_id")
  previousPeriodEnd DateTime? @map("previous_period_end") @db.Timestamptz(6)
  newPeriodEnd      DateTime @map("new_period_end") @db.Timestamptz(6)
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdByAdminId  String?  @map("created_by_admin_id")
  billingAlignmentStatus BillingAlignmentStatus @default(NOT_REQUIRED) @map("billing_alignment_status")

  user              User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transferRequest   SubscriptionTransferRequest @relation(fields: [transferRequestId], references: [id], onDelete: Cascade)
  subscription      Subscription?              @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("subscription_credit_ledger")
}
