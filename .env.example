# ========================================
# KeenVPN Backend v2 - Environment Variables
# ========================================
# Copy this file to .env and fill in your values

# ========================================
# Application Configuration
# ========================================
NODE_ENV=development
PORT=3000

# ========================================
# Database Configuration (PostgreSQL)
# ========================================
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL=postgresql://keen_user:keen_password@localhost:5432/keen_db?schema=public

# ========================================
# Redis Configuration
# ========================================
REDIS_URL=redis://localhost:6379

# ========================================
# Firebase Configuration
# ========================================
# Required for Firebase Admin SDK authentication
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-firebase-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-firebase-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
# Optional
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project.iam.gserviceaccount.com

# ========================================
# Stripe Configuration
# ========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Optional - Price IDs for subscription plans
STRIPE_INDIVIDUAL_ANNUAL_PRICE_ID=price_your_annual_price_id_here
STRIPE_INDIVIDUAL_MONTHLY_PRICE_ID=price_your_monthly_price_id_here

# ========================================
# Apple IAP Configuration
# ========================================
# Optional - Required for Apple In-App Purchase verification
APPLE_SHARED_SECRET=your_apple_shared_secret
APPLE_KEY_ID=your_apple_key_id
APPLE_ISSUER_ID=your_apple_issuer_id
APPLE_BUNDLE_ID=com.yourcompany.yourapp

# ========================================
# Blind Signing Configuration
# ========================================
# Required for VPN token blind signing (RSA-FDH)
# Generate a private key: openssl genrsa -out blind_signing_key.pem 2048
BLIND_SIGNING_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_RSA_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# ========================================
# JWT Configuration
# ========================================
# Optional - For additional JWT operations if needed
JWT_SECRET=your_jwt_secret_min_32_characters_long

# ========================================
# Config Service
# ========================================
CONFIG_CLIENT_TOKEN=your_config_client_token
APP_AWS_ACCESS_KEY_ID=aws_access_id
APP_AWS_SECRET_ACCESS_KEY=aws_access_secret
APP_AWS_REGION=us-east-1

# ========================================
# Slack Configuration
# ========================================
# Webhook URL for error/system alerts (existing)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Webhook URL for #server-requests channel (server location request notifications)
SLACK_SERVER_REQUESTS_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SERVER_REQUESTS/WEBHOOK

# ========================================
# Resend Transactional Email Configuration
# ========================================
# Optional - transactional emails are skipped when RESEND_API_KEY is not set
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM="KeenVPN <no-reply@vpnkeen.com>"
SUPPORT_EMAIL=support@vpnkeen.com
SALES_EMAIL=sales@vpnkeen.com
ACCOUNT_URL=https://vpnkeen.com/account